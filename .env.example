# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is in .gitignore.

# Gemini AI — get from aistudio.google.com → Get API Key
GEMINI_API_KEY=

# OpenRouteService — get from openrouteservice.org → Sign up → Dashboard → Tokens
ORS_API_KEY=

# MongoDB Atlas — get from atlas.mongodb.com → Create free cluster → Connect → Drivers → Node.js
MONGODB_URI=

# App URL — use http://localhost:3000 for local dev
NEXT_PUBLIC_APP_URL=http://localhost:3000
